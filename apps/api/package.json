{
  "name": "@leashmarket/api",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "leash-api": "./dist/cli.js",
    "leash-indexer": "./dist/indexer/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node --env-file-if-exists=.env dist/cli.js",
    "indexer": "node --env-file-if-exists=.env dist/indexer/cli.js",
    "indexer:dev": "node --env-file-if-exists=.env --import tsx ./src/indexer/cli.ts",
    "db:migrate": "node --env-file-if-exists=.env --import tsx ./scripts/db-migrate.ts",
    "dev": "node --env-file-if-exists=.env --import tsx ./src/dev.ts",
    "dev:watch": "node --env-file-if-exists=.env --import tsx watch ./src/dev.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo lint:api",
    "test": "vitest run",
    "e2e:devnet": "node --env-file-if-exists=.env --env-file-if-exists=.env.e2e --import tsx ./scripts/e2e-devnet.ts",
    "e2e:devnet:mpp": "node --env-file-if-exists=.env --env-file-if-exists=.env.e2e --import tsx ./scripts/e2e-devnet.ts",
    "e2e:upstream-paywall": "node --env-file-if-exists=.env --env-file-if-exists=.env.e2e --import tsx ./scripts/e2e-upstream-paywall.ts",
    "e2e:upstream-post-body": "node --env-file-if-exists=.env --env-file-if-exists=.env.e2e --import tsx ./scripts/e2e-upstream-post-body.ts",
    "withdraw": "node --env-file-if-exists=.env --env-file-if-exists=.env.e2e --import tsx ./scripts/withdraw.ts",
    "fund": "node --env-file-if-exists=.env --env-file-if-exists=.env.e2e --import tsx ./scripts/fund.ts",
    "facilitator:smoke": "node --env-file-if-exists=.env --env-file-if-exists=.env.e2e --import tsx ./scripts/facilitator-sdk-smoke.ts",
    "seed:demo": "node --env-file-if-exists=.env --import tsx ./scripts/seed-demo.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^0.18.0",
    "@leashmarket/buyer-kit": "workspace:*",
    "@leashmarket/core": "workspace:*",
    "@leashmarket/platform-auth": "workspace:*",
    "@leashmarket/registry-utils": "workspace:*",
    "@leashmarket/schemas": "workspace:*",
    "@leashmarket/seller-kit": "workspace:*",
    "@libsql/client": "^0.14.0",
    "@metaplex-foundation/mpl-agent-registry": "^0.2.5",
    "@metaplex-foundation/mpl-core": "^1.10.0",
    "@metaplex-foundation/mpl-toolbox": "^0.10.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@solana/kit": "^5.5.1",
    "baileys": "7.0.0-rc.9",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1",
    "ulid": "^2.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
