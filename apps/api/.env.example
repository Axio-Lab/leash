# Network RPC endpoints (server-owned). Defaults to Solana public clusters.
LEASH_API_RPC_DEVNET=https://api.devnet.solana.com
LEASH_API_RPC_MAINNET=https://api.mainnet-beta.solana.com

# Turso/SQLite database (libsql).
# Relative `file:./…` is resolved from each process cwd — API, indexer, and
# explorer may disagree. For dev, prefer one absolute path shared by all:
#   LEASH_API_DB_URL=file:/Users/you/leash-data/leash-dev.db
# For hosted Turso/libsql, set LEASH_API_DB_AUTH_TOKEN (see Turso dashboard).
LEASH_API_DB_URL=file:./.leash-api.db
# The internal explorer also reads this DB; see apps/explorer/.env.example
# (use the same URL or an absolute path so API + explorer share one file).
# LEASH_API_DB_AUTH_TOKEN=

# Redis (optional in dev, REQUIRED in prod / multi-process deploys).
# Backs api-key cache, per-key sliding-minute rate limit, and 24h Idempotency-Key
# de-dupe. When unset, single-process in-memory fallbacks are used (state lost
# on restart, no coordination across processes).
#
# Local dev (Homebrew): `brew services start redis` then use the URL below.
# Production examples:
#   redis://default:<password>@redis.<region>.upstash.io:6379
#   rediss://default:<password>@<host>:6380   (TLS — use `rediss://`)
LEASH_API_REDIS_URL=redis://127.0.0.1:6379

# Bind host/port.
LEASH_API_HOST=0.0.0.0
LEASH_API_PORT=8801

# Default API key rate limit (requests per minute, per key).
LEASH_API_RATELIMIT_RPM=120

# Bootstrap key. If set, the server will register this exact key (with the
# `lsh_test_` or `lsh_live_` prefix) on first start. Useful for local dev so
# you can curl the API immediately. Leave empty in production.
# LEASH_API_BOOTSTRAP_KEY=lsh_test_dev_localdev_only_replace
# LEASH_API_BOOTSTRAP_KEY_LABEL=dev-bootstrap

# Admin secret. When set, enables /v1/admin/api-keys for issuing/listing/revoking
# customer API keys. POST create requires JSON `owner_wallet` (Solana base58).
# List responses include `owner_wallet` (null for keys created before that column
# or for LEASH_API_BOOTSTRAP_KEY rows). When unset, admin requests return 503.
# Must be >= 32 chars. Generate with:  openssl rand -hex 32
# Send as `Authorization: Bearer <secret>` or `X-Admin-Secret: <secret>`.
# NEVER expose to end users; rotate on suspected compromise.
# LEASH_API_ADMIN_SECRET=

# Swagger UI at /docs (and / -> /docs redirect). Defaults to ON in non-prod
# (NODE_ENV !== 'production') and OFF in prod. Override here:
# LEASH_API_DOCS_ENABLED=false

# Hosted x402 facilitator the API uses for its own paywall (`/x/{id}`).
# This URL is also recorded on every `earn` receipt the paywall emits so
# explorers can re-verify settlement.
#
# Devnet default:  https://devnet-facilitator.leash.market
# Mainnet default: https://facilitator.leash.market  (set via LEASH_API_FACILITATOR_URL_MAINNET)
#
# For local dev, run `pnpm --filter @leash/facilitator-app dev` and point here:
# LEASH_API_FACILITATOR_URL=http://localhost:8787
# LEASH_API_FACILITATOR_URL_MAINNET=https://facilitator.leash.market

# Public origin the API is reachable on (e.g. https://api.leash.market).
# Used to compose paywall `share_url`s on payment-link create/preview and
# stamped onto the `request.url` of every paywall-served receipt. Defaults
# to http://<host>:<port> so local dev needs no override.
# LEASH_API_PUBLIC_ORIGIN=https://api.leash.market

# Base URL of the Leash protocol explorer (apps/explorer): `/receipt/{hash}`,
# `/tx/{sig}`. Used for user-facing links in external chat settlement
# messages. Do NOT set this to LEASH_API_PUBLIC_ORIGIN — the API host
# does not serve `/receipt/*`. Defaults to https://explorer.leash.market.
# Local dev (same as apps/agents NEXT_PUBLIC_EXPLORER_URL):
# LEASH_EXPLORER_URL=http://localhost:3100

# AES-GCM encryption key for LLM keys + API key plaintexts stored in the DB.
# Must be 64 hex chars (32 bytes). REQUIRED for agent creation and API key reveal.
# Must match the ENCRYPTION_KEY in apps/agents and apps/marketplace envs.
# Generate a fresh value with:  openssl rand -hex 32
# ENCRYPTION_KEY=

# Note: `LEASH_API_FAUCET_SECRET` was removed in v0.2 — the API no
# longer holds any keypairs. Agents are minted client-side by the
# MCP / CLI / SDK using a user-controlled executive keypair, and
# `POST /v1/agents/record` only reads the resulting asset from RPC
# to write the platform row. No server-side keypair is required.

# ─── External chat bridges (Telegram + WhatsApp) ──────────────────────
# When the apps/api Telegram dispatcher receives a webhook update, it
# invokes `POST /api/agents/run` on apps/agents to actually run the
# agent loop. Set both fields together; leave both unset to disable
# external chat bridges.
#
# `LEASH_AGENTS_BFF_URL` is the apps/agents origin (no trailing slash).
# `LEASH_AGENTS_BFF_SECRET` MUST match `LEASH_AGENTS_ADMIN_SECRET` in
# apps/agents/.env. Generate with `openssl rand -hex 24`.
#
# `LEASH_AGENTS_PUBLIC_ORIGIN` — browser URL for apps/agents (approve
# deep-links: `/approve/{token}`). Defaults to the origin of
# `LEASH_AGENTS_BFF_URL`. Set explicitly when the API is on a public
# tunnel but agents are on a different host (otherwise approve links
# point at the API and return "missing api key").
# LEASH_AGENTS_PUBLIC_ORIGIN=https://your-agents-app.trycloudflare.com
# LEASH_AGENTS_BFF_URL=http://localhost:4100
# LEASH_AGENTS_BFF_SECRET=
#
# Telegram bridge debug logs (`[external:tg] …`) on the API terminal.
# Default: on in development (NODE_ENV !== production). Off during Vitest
# unless you set LEASH_EXTERNAL_TELEGRAM_LOG=1. Set to 0 to silence locally;
# set to 1 to force on in production builds.
# LEASH_EXTERNAL_TELEGRAM_LOG=1
#
# Baileys → libsignal logs huge "Closing session" SessionEntry dumps to the
# console. Default: filtered out. Set to 1 to show raw libsignal noise.
# LEASH_LIBSIGNAL_VERBOSE=1
#
# WhatsApp (Baileys) runs inside apps/api on the designated host only.
# Set LEASH_WHATSAPP_ENABLED=1 on exactly one replica so multiple
# processes don't open duplicate WhatsApp Web sessions for the same
# libsql rows. Other replicas leave it unset; `/v1/external/whatsapp/*`
# returns 503 there while Telegram + approvals keep working.
# LEASH_WHATSAPP_ENABLED=
