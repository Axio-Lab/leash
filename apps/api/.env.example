# Network RPC endpoints (server-owned). Defaults to Solana public clusters.
LEASH_API_RPC_DEVNET=https://api.devnet.solana.com
LEASH_API_RPC_MAINNET=https://api.mainnet-beta.solana.com

# Turso/SQLite database (libsql).
# Relative `file:./…` is resolved from each process cwd — API, indexer, and
# explorer may disagree. For dev, prefer one absolute path shared by all:
#   LEASH_API_DB_URL=file:/Users/you/leash-data/leash-dev.db
# For hosted Turso/libsql, set LEASH_API_DB_AUTH_TOKEN (see Turso dashboard).
LEASH_API_DB_URL=file:./.leash-api.db
# The internal explorer also reads this DB; see apps/explorer/.env.example
# (use the same URL or an absolute path so API + explorer share one file).
# LEASH_API_DB_AUTH_TOKEN=

# Redis (optional in dev, REQUIRED in prod / multi-process deploys).
# Backs api-key cache, per-key sliding-minute rate limit, and 24h Idempotency-Key
# de-dupe. When unset, single-process in-memory fallbacks are used (state lost
# on restart, no coordination across processes).
#
# Local dev (Homebrew): `brew services start redis` then use the URL below.
# Production examples:
#   redis://default:<password>@redis.<region>.upstash.io:6379
#   rediss://default:<password>@<host>:6380   (TLS — use `rediss://`)
LEASH_API_REDIS_URL=redis://127.0.0.1:6379

# Bind host/port.
LEASH_API_HOST=0.0.0.0
LEASH_API_PORT=8801

# Default API key rate limit (requests per minute, per key).
LEASH_API_RATELIMIT_RPM=120

# Bootstrap key. If set, the server will register this exact key (with the
# `lsh_test_` or `lsh_live_` prefix) on first start. Useful for local dev so
# you can curl the API immediately. Leave empty in production.
# LEASH_API_BOOTSTRAP_KEY=lsh_test_dev_localdev_only_replace
# LEASH_API_BOOTSTRAP_KEY_LABEL=dev-bootstrap

# Admin secret. When set, mounts /v1/admin/api-keys for issuing/listing/revoking
# customer API keys. When unset, the admin surface does not exist at all.
# Must be >= 32 chars. Generate with:  openssl rand -hex 32
# Send as `Authorization: Bearer <secret>` or `X-Admin-Secret: <secret>`.
# NEVER expose to end users; rotate on suspected compromise.
# LEASH_API_ADMIN_SECRET=

# Swagger UI at /docs (and / -> /docs redirect). Defaults to ON in non-prod
# (NODE_ENV !== 'production') and OFF in prod. Override here:
# LEASH_API_DOCS_ENABLED=false

# Hosted x402 facilitator the API uses for its own paywall (`/x/{id}`).
# This URL is also recorded on every `earn` receipt the paywall emits so
# explorers can re-verify settlement.
#
# Devnet default:  https://devnet-facilitator.leash.market
# Mainnet default: https://facilitator.leash.market  (set via LEASH_API_FACILITATOR_URL_MAINNET)
#
# For local dev, run `pnpm --filter @leash/facilitator-app dev` and point here:
# LEASH_API_FACILITATOR_URL=http://localhost:8787
# LEASH_API_FACILITATOR_URL_MAINNET=https://facilitator.leash.market

# Public origin the API is reachable on (e.g. https://api.leash.market).
# Used to compose paywall `share_url`s on payment-link create/preview and
# stamped onto the `request.url` of every paywall-served receipt. Defaults
# to http://<host>:<port> so local dev needs no override.
# Also drives the OpenAPI / Swagger "Servers" URL when set (so production
# + LEASH_API_DOCS_ENABLED=true does not show http://localhost:$PORT).
# LEASH_API_PUBLIC_ORIGIN=https://api.leash.market
