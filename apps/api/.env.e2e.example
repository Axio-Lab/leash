# ────────────────────────────────────────────────────────────────────────────
# Env for `pnpm --filter @leashmarket/api e2e:devnet`.
# Copy to .env.e2e and fill in real values. NEVER commit .env.e2e.
# ────────────────────────────────────────────────────────────────────────────

# Required: where the script talks to (no trailing slash).
LEASH_E2E_API_URL=http://localhost:8801

# Required: a devnet API key issued via POST /v1/admin/api-keys.
# Must start with `lsh_test_`.
LEASH_E2E_API_KEY=lsh_test_replace_me

# Required: agent owner wallet secret. Either base58 OR a JSON array.
#   solana-keygen new -o /tmp/owner.json
#   cat /tmp/owner.json   # → [12,34,56,…]
LEASH_E2E_OWNER_SECRET=

# Optional — devnet RPC the script signs through (createBuyer + umi).
# LEASH_E2E_RPC=https://api.devnet.solana.com

# Optional — currency to settle in. Defaults to Circle's official devnet USDC.
# LEASH_E2E_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Optional — devnet USDG mint (Token-2022). If buyer treasury has enough balance,
# a second settlement pass is run paying in USDG.
# LEASH_E2E_USDG_MINT=4F6PM96JJxngmHnZLBh9n58RH4aTVNWvDs2nuwrT5BP7

# Optional — display price the paywall is created with.
# LEASH_E2E_PRICE=$0.001

# Optional — reuse existing agents (skip the on-chain mint step).
# LEASH_E2E_SELLER_AGENT=
# LEASH_E2E_BUYER_AGENT=

# Optional — atomic USDC units the buyer treasury should hold before settling.
# LEASH_E2E_FUND_USDC=100000

# Optional — atomic USDG units the buyer treasury should hold for the USDG pass.
# Set to 0 to skip USDG settlement entirely.
# LEASH_E2E_FUND_USDG=5000000

# Optional — atomic USDC units the SPL `approve` allowance should cover.
# LEASH_E2E_DELEGATE_USDC=100000

# Optional — atomic USDG units the Token-2022 `approve` allowance should cover.
# LEASH_E2E_DELEGATE_USDG=5000000

# Optional — set to `1` to skip the soft-disable cleanup so you can poke the
# generated link in the explorer.
# LEASH_E2E_KEEP_LINK=0
