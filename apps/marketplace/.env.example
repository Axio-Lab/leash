# ─── Privy ────────────────────────────────────────────────────────────
# Same Privy app: server `verifyAuthToken` requires
# `PRIVY_APP_ID === NEXT_PUBLIC_PRIVY_APP_ID`.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── Leash API (BFF talks to /v1/admin endpoints with this secret) ────
# In prod set `LEASH_API_URL=https://api.leash.market` (or your own
# api host). `LEASH_API_ADMIN_SECRET` MUST match the value configured
# on `apps/api`.
LEASH_API_URL=http://localhost:8801
LEASH_API_ADMIN_SECRET=

# ─── Shared Turso DB (same DB as apps/api + apps/agents) ──────────────
# Local dev uses the SQLite file produced by `apps/api`. For
# Railway/Fly/etc, point this at your Turso libsql:// URL and set
# `LEASH_DB_AUTH_TOKEN` to the Turso token.
LEASH_DB_URL=file:../api/.leash-api.db
LEASH_DB_AUTH_TOKEN=

# ─── Cross-app links (browser-side, baked at build time) ──────────────
# `NEXT_PUBLIC_AGENTS_URL` is the public URL of the agents app and is
# linked to from creator pages + listing detail. Match the deployed
# Solana RPC + network with the agents app so manifests + price quotes
# resolve against the same chain.
NEXT_PUBLIC_AGENTS_URL=http://localhost:4100
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=solana-devnet

# ─── Explorer base URL (used in creator/tools detail page) ────────────
# Defaults to https://explorer.leash.market when unset. Bake at build
# time alongside the other NEXT_PUBLIC_* vars.
NEXT_PUBLIC_EXPLORER_URL=https://explorer.leash.market

# ─── Admin moderation queue ──────────────────────────────────────────
# Comma-separated Privy ids that can access /creator/admin/queue and
# approve listings. Leave empty to disable the admin surface entirely.
LEASH_ADMIN_PRIVY_IDS=
