# Same Privy app: server `verifyAuthToken` requires PRIVY_APP_ID === NEXT_PUBLIC_PRIVY_APP_ID.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# `apps/api` listens on 8801 by default (LEASH_API_PORT in apps/api/.env).
LEASH_API_URL=http://localhost:8801
LEASH_API_ADMIN_SECRET=

LEASH_DB_URL=file:../api/.leash-api.db
LEASH_DB_AUTH_TOKEN=

NEXT_PUBLIC_AGENTS_URL=http://localhost:4100

# Browser-side Solana (embedded wallet + manifest validation). Match agents.
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=solana-devnet

# Comma-separated Privy ids that can access /admin/queue and approve listings.
LEASH_ADMIN_PRIVY_IDS=
