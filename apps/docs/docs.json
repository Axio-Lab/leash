            "pages": [
              "guides/create-an-agent",
              "guides/bring-your-own-keypair",
              "guides/fund-an-agent",
              "guides/create-an-endpoint",
              "guides/build-a-seller",
              "guides/build-a-buyer",
              "guides/build-a-merged-agent",
              "guides/withdraw-funds",
              "guides/launch-agent-token",
              "guides/pause-an-agent",
              "guides/run-a-facilitator"
