{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Leash",
  "description": "An open rail for agents that spend on the open internet.",
  "theme": "maple",
  "favicon": "/leash_icon.svg",
  "logo": {
    "light": "/leash_icon.svg",
    "dark": "/leash_icon.svg"
  },
  "colors": {
    "primary": "#9b8cff",
    "light": "#bca8ff",
    "dark": "#1a1533"
