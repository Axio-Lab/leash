{
  "name": "@leashmarket/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "leash-agent-runtime": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:migrate": "node --env-file-if-exists=.env --import tsx ../api/scripts/db-migrate.ts",
    "dev": "pnpm run db:migrate && node --env-file-if-exists=.env --import tsx ./src/cli.ts",
    "start": "node --env-file-if-exists=.env dist/cli.js",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@leashmarket/platform-auth": "workspace:*",
    "@libsql/client": "^0.14.0",
    "ioredis": "^5.4.1",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
