# Shared Turso DB (same as apps/api).
LEASH_DB_URL=file:../api/.leash-api.db
LEASH_DB_AUTH_TOKEN=

# Redis (publish channel for SSE bridge).
LEASH_REDIS_URL=redis://127.0.0.1:6379

# AES-256-GCM key for decrypting agent LLM keys.
ENCRYPTION_KEY=

# Poll interval (ms) when no tasks are queued.
LEASH_RUNTIME_POLL_MS=750
