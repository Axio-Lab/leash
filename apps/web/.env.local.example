# Privy — REQUIRED for the wallet button + login flows.
# Dashboard: https://dashboard.privy.io → App ID (public, safe in the browser).
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: **App client** id only (Configuration → App settings → Clients).
# NEVER set `privy_app_secret_…` here — that is the **app secret** (server-only).
# If you paste the secret by mistake, email login will fail; rotate the secret
# in the dashboard after removing it from this file.
# NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Solana RPC used by the embedded wallet & seller `payTo` resolution.
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# `@leash/runner` HTTP base. The web app proxies /health, /pause, and the
# receipt feed through its own API routes so the browser never speaks to the
# runner directly.
LEASH_RUNNER_URL=http://localhost:8787
