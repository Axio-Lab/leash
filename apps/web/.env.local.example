# Privy — REQUIRED for the wallet button + login flows.
# Dashboard: https://dashboard.privy.io → App ID (public, safe in the browser).
# The connected Privy wallet is also the signer for `createAgent`,
# `registerExecutiveV1`, and `delegateExecutionV1` in the playground.
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: **App client** id only (Configuration → App settings → Clients).
# NEVER set `privy_app_secret_…` here — that is the **app secret** (server-only).
# If you paste the secret by mistake, email login will fail; rotate the secret
# in the dashboard after removing it from this file.
# NEXT_PUBLIC_PRIVY_CLIENT_ID=


NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# One of: `solana-mainnet`, `solana-devnet`
NEXT_PUBLIC_SOLANA_NETWORK=solana-devnet


# `@leash/runner` HTTP base. The web app proxies /health, /pause, and the
# receipt feed through its own API routes so the browser never speaks to the
# runner directly.
LEASH_RUNNER_URL=http://localhost:8787

# OPTIONAL — facilitator URL the buyer playground (`/buyer`) and any
# server-side seller routes use to verify + settle x402 payments.
#
# Resolution order in @leash/buyer-kit / @leash/seller-kit:
#   1. The `facilitator: …` arg passed programmatically.
#   2. This env var.
#   3. defaultFacilitatorFor(network) from @leash/core/x402.
#
# Set to https://facilitator.leash.dev to route through the
# Leash-operated devnet facilitator (v0.1, devnet only). Or point at
# `http://localhost:8787` to test against `apps/facilitator` running
# locally — see `apps/docs/guides/run-a-facilitator.mdx`.
# LEASH_FACILITATOR_URL=https://facilitator.leash.dev

# OPTIONAL — Pinata JWT for the "Pin to Pinata for me" mode on /agents/new.
# Get one at https://app.pinata.cloud → API Keys (JWT). Stays server-side; the
# browser POSTs to /api/registry/pin which calls Pinata on its behalf.
# If unset, only the "I have a URI" mode works.
# PINATA_JWT=
# PINATA_GATEWAY=https://gateway.pinata.cloud   # optional custom gateway

# OPTIONAL — server-side fallback signer for headless callers (CI, cron,
# scripts). The browser playground signs every on-chain action with the
# user's Privy wallet, so this key is NOT needed for the standard demo
# flow. It is only used by:
#   POST /api/agents/create        (server fallback for createAgent)
#   POST /api/agents/executive     (server fallback for register/delegate)
# Accepts either a base58 string (Phantom export) or a JSON byte-array
# (`solana-keygen` format, e.g. `[1,2,3,…]`). NEVER reuse a mainnet key.
# LEASH_DEV_PAYER_SECRET_KEY=
