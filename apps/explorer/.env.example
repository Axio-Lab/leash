# Copy to `.env.local` (Next.js convention) or load via your process manager.
# The explorer accepts either `LEASH_*` (below) or the API aliases
# `LEASH_API_DB_*` / `LEASH_API_RPC_*` — same values as `apps/api/.env.example`.

# --- Database (libsql / Turso) -----------------------------------------------
#
# LOCAL FILE (no token):
#   Paths are relative to each process cwd. API defaults to
#   `apps/api/.leash-api.db`, explorer to `apps/explorer/.leash-api.db` unless
#   you set this — use one shared path for both when you run API + explorer.
#
# Monorepo (explorer reads the DB the API created):
LEASH_DB_URL=file:../api/.leash-api.db
#
# Explorer-only scratch DB (empty until something writes events):
# LEASH_DB_URL=file:./.leash-api.db
#
# Same absolute path everywhere (clearest for teams):
# LEASH_DB_URL=file:/Users/you/leash/.data/leash-api.db
#
# HOSTED TURSO (token required):
#   1. Create a DB in https://turso.tech (or your libsql host).
#   2. Copy the `libsql://…` connection URL → LEASH_DB_URL
#   3. Create a DB auth token in the Turso dashboard → LEASH_DB_AUTH_TOKEN
#      (Turso: Database → Settings → "Create token", or CLI `turso db tokens create`).
#
# LEASH_DB_URL=libsql://your-db-name-your-org.turso.io
# LEASH_DB_AUTH_TOKEN=eyJ…

# --- Solana RPC (read-only, server-side) -----------------------------------
# Defaults are the public cluster endpoints if you omit these.
# For production, use your provider (Helius, QuickNode, Triton, etc.) — paste
# the full HTTPS URL they give you (often includes an API key in the path).
#
LEASH_RPC_DEVNET=https://api.devnet.solana.com
LEASH_RPC_MAINNET=https://api.mainnet-beta.solana.com
