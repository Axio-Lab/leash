# ─── Privy ────────────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── Leash API (BFF talks to /v1/admin endpoints with this secret) ────
LEASH_API_URL=http://localhost:8787
LEASH_API_ADMIN_SECRET=

# ─── Shared Turso DB (same as apps/api) ───────────────────────────────
LEASH_DB_URL=file:../api/.leash-api.db
LEASH_DB_AUTH_TOKEN=

# ─── Redis (for SSE bridge to agent-runtime activity feed) ────────────
LEASH_REDIS_URL=redis://127.0.0.1:6379

# ─── Solana RPC (for browser-side mint via Privy + Umi) ───────────────
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=solana-devnet

# ─── Encryption key for storing user LLM keys (32-byte hex) ───────────
ENCRYPTION_KEY=
