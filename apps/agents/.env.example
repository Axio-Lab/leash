# ─── Privy ────────────────────────────────────────────────────────────
# `PRIVY_APP_ID` MUST equal `NEXT_PUBLIC_PRIVY_APP_ID` (the server
# verifies JWTs minted by the same Privy app the browser signs into).
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── Leash API (BFF talks to /v1/admin endpoints with this secret) ────
# In prod set `LEASH_API_URL=https://api.leash.market` (or your own
# api host). `LEASH_API_ADMIN_SECRET` MUST match the value configured
# on `apps/api`.
LEASH_API_URL=http://localhost:8801
LEASH_API_ADMIN_SECRET=

# ─── Shared Turso DB (same DB as apps/api) ────────────────────────────
# Local dev uses the SQLite file produced by `apps/api`. For
# Railway/Fly/etc, point this at your Turso libsql:// URL and set
# `LEASH_DB_AUTH_TOKEN` to the Turso token.
LEASH_DB_URL=file:../api/.leash-api.db
LEASH_DB_AUTH_TOKEN=

# ─── Solana RPC (browser-side mint via Privy + Umi) ───────────────────
NEXT_PUBLIC_SOLANA_RPC_MAINNET=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_DEVNET=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=solana-devnet

# ─── Explorer base URL (used for receipt/tx/agent links in chat) ──────
# Defaults to https://explorer.leash.market when unset. Bake at build
# time alongside the other NEXT_PUBLIC_* vars.
NEXT_PUBLIC_EXPLORER_URL=https://explorer.leash.market

# ─── Encryption key for storing user LLM keys (32-byte hex) ───────────
# Generate with `openssl rand -hex 32`. MUST match the same value in
# `apps/api/.env` so encrypted rows stay readable across services.
ENCRYPTION_KEY=

# ─── Platform Anthropic key (fallback when user hasn't added their own) ─
# Required for the chat brain. Without it, agent turns fall back to a
# deterministic stub reply ("Got it — deterministic stub reply…").
ANTHROPIC_API_KEY=

# ─── Composio (toolkit catalog + OAuth-style tool calls) ──────────────
# Required for the connections panel + tool router. Without it, the
# /api/composio routes return a friendly "not configured" warning.
COMPOSIO_API_KEY=

# ─── Per-tier Claude model ids ────────────────────────────────────────
# Each user picks a tier (Haiku / Sonnet / Opus) in Profile → LLM and
# the agent runs against the model id wired here. Defaults track the
# latest stable Anthropic releases:
#   haiku  → claude-haiku-4-5
#   sonnet → claude-sonnet-4-5   (platform default)
#   opus   → claude-opus-4-1
# Override one or all to pin a different revision.
# LEASH_AGENT_MODEL_HAIKU=claude-haiku-4-5
# LEASH_AGENT_MODEL_SONNET=claude-sonnet-4-5
# LEASH_AGENT_MODEL_OPUS=claude-opus-4-1

# ─── Hard model override (wins over per-user tier) ────────────────────
# Only set this when every chat must pin to a specific model regardless
# of the user's selection — useful for tests / staging snapshots.
# LEASH_AGENT_MODEL=

# ─── External chat bridges (Telegram + WhatsApp) ──────────────────────
# Shared secret the apps/api Telegram dispatcher uses to invoke the
# run-on-behalf BFF endpoint at `POST /api/agents/run`. Generate with
# `openssl rand -hex 24`. Must match `LEASH_AGENTS_BFF_SECRET` in
# `apps/api/.env`. Leave unset to disable external bridges.
LEASH_AGENTS_ADMIN_SECRET=

# ─── Tests / offline dev only — leave UNSET in production ─────────────
# When `LEASH_AGENT_STUB=1`, every chat turn returns a deterministic
# stub reply so smoke tests don't hit the live LLM.
# LEASH_AGENT_STUB=
