# Required ─ Solana keypair the facilitator uses as fee payer.
#
# Easy way (matches `solana-keygen new` output):
#   solana-keygen new -o .leash-fee-payer.json --no-bip39-passphrase
#   export LEASH_FACILITATOR_SECRET_KEY="$(cat .leash-fee-payer.json)"
#   solana airdrop 1 -k .leash-fee-payer.json --url https://api.devnet.solana.com
#
# Accepted formats:
#   - Solana CLI JSON byte array, e.g. [12,34,56,...]
#   - base58 64-byte secret (Phantom "export private key" output)
LEASH_FACILITATOR_SECRET_KEY=

# Comma-separated. Default: devnet. Allowed: devnet, testnet, mainnet.
# v0.1 of facilitator.leash.dev runs devnet only.
LEASH_FACILITATOR_NETWORKS=devnet

# HTTP listener config.
LEASH_FACILITATOR_PORT=8787
LEASH_FACILITATOR_HOST=0.0.0.0

# Optional: override the default RPC URL used for ALL networks.
# Per-network defaults from @solana/kit are used when unset.
# LEASH_FACILITATOR_RPC_URL=https://api.devnet.solana.com
