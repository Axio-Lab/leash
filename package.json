{
  "name": "leash",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ci": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm build && pnpm test",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint --continue",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:devnet": "RUN_DEVNET=1 turbo run test:devnet",
    "gen:docs": "node scripts/gen-schema-docs.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "prepare": "sh -c 'git rev-parse --git-dir >/dev/null 2>&1 && husky || true'"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.16.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
