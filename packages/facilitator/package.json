{
  "name": "@leashmarket/facilitator",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "leash-facilitator": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@leashmarket/core": "workspace:*",
    "@solana-program/compute-budget": "^0.11.0",
    "@solana-program/token": "^0.6.0",
    "@solana-program/token-2022": "^0.6.1",
    "@solana/kit": "^5.1.0",
    "@x402/core": "^2.10.0",
    "@x402/svm": "^2.10.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
