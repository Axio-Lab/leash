{
  "name": "@leashmarket/testing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "leash-conformance": "./dist/cli/conformance.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "echo lint:testing",
    "pretest": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@leashmarket/core": "workspace:*",
    "@leashmarket/schemas": "workspace:*",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
