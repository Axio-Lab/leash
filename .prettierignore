# Mintlify-served plain-text manifests for AI tools. Plain markdown links
# wrapped at sentence boundaries — prettier has no parser for `.txt` and
# would reject them outright.
apps/docs/llms.txt
apps/docs/llms-full.txt

# Generated by scripts/gen-schema-docs.mjs from packages/schemas/json/*.json.
apps/docs/schemas/*.mdx

# Build artefacts and lockfiles already covered by .gitignore.
**/dist/**
**/build/**
**/.next/**
**/node_modules/**
pnpm-lock.yaml

# Dotenv-style examples — no file extension Prettier recognises.
apps/web/.env.local.example
